 if [ $? -ne 0 ]; then
     echo 'Terminating...' >&2
     exit 1
@@ -88,6 +89,7 @@ while true; do
             echo "  rofi -show menu -modi \"menu:rofi-power-menu --choices=shutdown/reboot\""
             echo
             echo "Available options:"
+            echo "  --eng                Use english version text instead of polish"
             echo "  --dry-run            Don't perform the selected action but print it to stderr."
             echo "  --choices CHOICES    Show only the selected choices in the given order. Use /"
             echo "                       as the separator. Available choices are lockscreen,"
@@ -115,6 +117,10 @@ while true; do
             echo "  -h,--help            Show this help text."
             exit 0
             ;;
+        "--eng")
+            eng=true
+            shift 1
+            ;;
         "--dry-run")
             dryrun=true
             shift 1
@@ -166,6 +172,15 @@ while true; do
     esac
 done
 
+if [ "$eng" = "false" ]
+then
+    texts[lockscreen]="zablokuj"
+    texts[logout]="wyloguj"
+    texts[suspend]="uśpij"
+    texts[reboot]="uruchom ponownie"
+    texts[shutdown]="wyłącz"
+fi
+
 if [ "$showsymbols" = "false" -a "$showtext" = "false" ]
 then
     echo "Invalid options: cannot have --no-symbols and --no-text enabled at the same time." >&2

